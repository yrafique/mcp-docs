# ── secrets / local env (never commit) ──
*.env
.env
!*.env.example
.vault/
**/vault/
token*.json
*.pem
*.key
*.crt
# ── local-only CA drop-in (keep the dir, never commit a cert) ──
certs/*
!certs/.gitkeep
.enabled
# ── python caches ──
__pycache__/
*.pyc
*.pyo
.pytest_cache/
# ── os cruft ──
.DS_Store
Thumbs.db
