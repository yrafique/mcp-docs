# mcp-docs — runtime config. Copy to .env and fill; inject with `--env-file .env`.
# NEVER commit a filled-in .env. No secrets are baked into the image.
# Defaults target the bundled docs-db from compose.lab.yml — copy as-is to get started.
# Passwords/tokens are masked as <changeme>; fill in your own.

# --- required: docs-db (Postgres/ParadeDB). Seed it first from src/doc_store.sql.gz ---
DOCS_DATABASE_URL=postgresql://mcp:<changeme>@docs-db:5432/docs_db

# --- doc versions + hybrid search ---
DOCS_NSP_VERSION=26-4
DOCS_SROS_VERSION=26-3
DOCS_HYBRID=1
# DOCS_EMBED_MODEL=BAAI/bge-small-en-v1.5
# DOCS_EMBED_CACHE=/srv/models

# --- host SNAT target for the crawler (documentation.nokia.com) ---
# NOKIA_DOC_IP=<optional: pin documentation.nokia.com to an IP if needed>
NOKIA_DOC_HOST=documentation.nokia.com
